{
  "name": "appointment-workflow-assistant",
  "version": "0.1.0",
  "private": false,
  "description": "A compliance-first semi-automated appointment workflow assistant with manual verification checkpoints, scheduling, diagnostics, and result archiving.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/app.ts",
    "dev:watch": "node --watch --import tsx src/server/app.ts",
    "dashboard": "tsx src/server/app.ts",
    "dashboard:debug": "npm run build && DEBUG_AUTOMATION=1 node dist/server/app.js",
    "check": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:dashboard": "node dist/server/app.js",
    "build": "tsc"
  },
  "dependencies": {
    "@playwright/test": "^1.44.0",
    "express": "^4.19.2",
    "playwright": "^1.44.0",
    "tsx": "^4.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3"
  }
}
